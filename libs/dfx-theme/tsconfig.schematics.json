{
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "inlineSources": false,
    "module": "node16",
    "moduleResolution": "node16",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "../../dist/dfx-theme/schematics",
    "rootDir": "schematics",
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "sourceMap": false,
    "strictNullChecks": true,
    "target": "es2022",
    "types": ["node"]
  },
  "exclude": ["schematics/**/*.spec.ts"],
  "extends": "../../tsconfig.json",
  "include": ["schematics/**/*.ts"]
}
