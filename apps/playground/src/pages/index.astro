---
import '../styles/global.css';
import CardLoopScript from '../components/CardLoopScript.astro';
import { projects } from '../data/playground';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="generator" content={Astro.generator} />
  <meta name="author" content="Dafnik" />
  <title>playground.dafnik.me</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,500;6..72,700&display=swap"
    rel="stylesheet"
  />
</head>
<body class="playground-home">
<main class="page-shell">
  <section class="hero">
    <h1>playground</h1>
  </section>

  <section class="project-list" aria-label="Projects">
    {
      projects.map((project) => (
        <a data-loop-card class="project-card" href={project.href}>
          <div class="project-copy">
            <h2>{project.title}</h2>
            <p>{project.text}</p>
          </div>
          <span class="project-link">Open</span>
        </a>
      ))
    }
  </section>
</main>

<footer class="footer">
  <p>
    by
    <a href="https://dafnik.me" target="_blank" rel="noopener noreferrer">Dafnik</a>
  </p>
</footer>

<CardLoopScript interval={5000} />
</body>
</html>

<style>
  :global(body.playground-home) {
    margin: 0;
    min-height: 100vh;
    color: #0b0b0b;
    background:
      linear-gradient(180deg, rgba(228, 49, 28, 0.08), transparent 22%),
      #f6f3ec;
    font-family: 'Archivo', sans-serif;
  }

  .page-shell {
    width: min(1140px, calc(100vw - 2rem));
    margin: 0 auto;
    padding: 1.4rem 0 3rem;
  }

  .hero {
    display: grid;
    gap: 1rem;
    justify-items: center;
    text-align: center;
    padding: 6rem 0 3rem;
    border-bottom: 2px solid #0b0b0b;
  }

  .project-link {
    margin: 0;
    font-size: 0.8rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .hero h1 {
    margin: 0;
    font-family: 'Newsreader', serif;
    font-size: clamp(4rem, 12vw, 8.2rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.06em;
  }

  .lede {
    max-width: 36rem;
    margin: 0;
    line-height: 1.8;
    color: rgba(11, 11, 11, 0.72);
  }

  .project-list {
    display: grid;
    gap: 0;
    padding-top: 1rem;
  }

  .project-card {
    display: grid;
    gap: 1rem;
    align-items: start;
    padding: 1.15rem 0;
    border-bottom: 1px solid rgba(11, 11, 11, 0.18);
    color: inherit;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      color 0.2s ease,
      padding-left 0.2s ease,
      padding-right 0.2s ease;
  }

  .project-card:hover,
  .project-card.is-active {
    background: #0b0b0b;
    color: #f6f3ec;
    padding-left: 1rem;
    padding-right: 1rem;
  }

  .project-card:focus-visible {
    outline: 2px solid #e4311c;
    outline-offset: 5px;
  }

  .project-copy {
    word-break: keep-all;
    display: grid;
    gap: 0.5rem;
  }

  .project-card h2 {
    margin: 0;
    font-size: clamp(1.9rem, 4vw, 3.1rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
  }

  .project-card p {
    margin: 0;
    max-width: 34rem;
    line-height: 1.7;
    color: rgba(11, 11, 11, 0.72);
    transition: color 0.2s ease;
  }

  .project-card:hover p,
  .project-card.is-active p {
    color: rgba(246, 243, 236, 0.76);
  }

  .project-link {
    color: #e4311c;
  }

  .project-card:hover .project-link,
  .project-card.is-active .project-link {
    color: #f15d4a;
  }

  .footer {
    padding: 1.4rem 0 2rem;
    text-align: center;
    color: rgba(11, 11, 11, 0.56);
  }

  .footer a {
    color: #0b0b0b;
    text-decoration: none;
  }

  .footer a:hover {
    text-decoration: underline;
  }

  @media (min-width: 900px) {
    .project-card {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 1.4rem;
      align-items: center;
    }

    .project-link {
      justify-self: end;
    }
  }
</style>
