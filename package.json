{
  "name": "dfx-common",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "build": "ng build dfx-bootstrap-table && ng build dfx-bootstrap-table-demo && ng build dfx-helper && ng build dfx-openapi && ng build dfx-qrcode && ng build dfx-qrcode-demo && ng build dfx-transloco-markup && ng build dfx-transloco-markup-demo && pnpm build:dfx-theme && ng build dfx-theme-demo && ng build dfx-opa && ng build dfx-opa-demo",
    "build:dfx-theme": "ng build dfx-theme && tsc -p libs/dfx-theme/tsconfig.schematics.json && node -e \"require('node:fs').renameSync('dist/dfx-theme/schematics/ng-add/index.js', 'dist/dfx-theme/schematics/ng-add/index.cjs')\"",
    "test": "ng test dfx-bootstrap-table --watch false && ng test dfx-helper --watch false && ng test dfx-openapi --watch false && ng test dfx-qrcode --watch false && ng test dfx-transloco-markup --watch false && ng test dfx-theme --watch false && ng test dfx-opa --watch false",
    "build:playground": "pnpm -C apps/playground build",
    "preview:playground": "pnpm -C apps/playground preview",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "ng lint dfx-bootstrap-table && ng lint dfx-helper && ng lint dfx-openapi && ng lint dfx-qrcode && ng lint dfx-transloco-markup && ng lint dfx-theme && ng lint dfx-opa",
    "http:dfx-qrcode-demo": "ng build dfx-qrcode-demo && angular-http-server --path ./dist/dfx-qrcode-demo/browser --baseHref qrcode",
    "http:dfx-bootstrap-table-demo": "ng build dfx-bootstrap-table-demo && angular-http-server --path ./dist/dfx-bootstrap-table-demo/browser --baseHref bootstrap-table",
    "http:dfx-transloco-markup-demo": "ng build dfx-transloco-markup-demo && angular-http-server --path ./dist/dfx-transloco-markup-demo/browser --baseHref transloco-markup",
    "http:dfx-theme-demo": "ng build dfx-theme-demo && angular-http-server --path ./dist/dfx-theme-demo/browser --baseHref theme",
    "http:dfx-opa-demo": "ng build dfx-opa-demo && angular-http-server --path ./dist/dfx-opa-demo/browser --baseHref opa",
    "http:playground": "pnpm build:playground && http-server ./apps/playground/dist/",
    "serve:ssr:dfx-transloco-markup-demo": "node dist/dfx-transloco-markup-demo/server/server.mjs",
    "serve:ssr:dfx-theme-demo": "node dist/dfx-theme-demo/server/server.mjs",
    "serve:ssr:dfx-opa-demo": "node dist/dfx-opa-demo/server/server.mjs",
    "serve:opa-server": "opa run --server ./apps/dfx-opa-demo/demo.rego",
    "serve:opa-demo": "ng serve dfx-opa-demo --configuration=opa-server & pnpm serve:opa-server"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "22.0.4",
    "@angular/common": "22.0.6",
    "@angular/compiler": "22.0.6",
    "@angular/core": "22.0.6",
    "@angular/forms": "22.0.6",
    "@angular/platform-browser": "22.0.6",
    "@angular/platform-server": "22.0.6",
    "@angular/router": "22.0.6",
    "@angular/ssr": "22.0.6",
    "@jsverse/transloco": "8.4.0",
    "@ng-icons/core": "<35.0.0",
    "@ng-icons/lucide": "<35.0.0",
    "@open-policy-agent/opa": "2.0.0",
    "@shikijs/langs": "4.3.1",
    "@shikijs/themes": "4.3.1",
    "@spartan-ng/brain": "1.1.0",
    "bootstrap": "5.3.8",
    "class-variance-authority": "0.7.1",
    "clsx": "^2.1.1",
    "dfts-helper": "2.1.0",
    "dfts-qrcode": "1.1.1",
    "express": "5.2.1",
    "openapi-typescript-helpers": "0.1.0",
    "rxjs": "7.8.2",
    "shiki": "4.3.1",
    "tailwind-merge": "3.6.0",
    "tslib": "2.8.1"
  },
  "packageManager": "pnpm@11.11.0",
  "devDependencies": {
    "@angular-devkit/core": "22.0.6",
    "@angular-devkit/schematics": "22.0.6",
    "@angular-eslint/builder": "22.1.0",
    "@angular/build": "22.0.6",
    "@angular/cli": "22.0.6",
    "@angular/compiler-cli": "22.0.6",
    "@eslint/js": "10.0.1",
    "@spartan-ng/cli": "1.1.0",
    "@tailwindcss/postcss": "4.3.2",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/express": "5.0.6",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "angular-eslint": "22.1.0",
    "angular-http-server": "1.12.0",
    "eslint": "10.7.0",
    "git-cliff": "2.13.1",
    "http-server": "14.1.1",
    "jsdom": "29.1.1",
    "ng-packagr": "22.0.1",
    "postcss": "8.5.18",
    "prettier": "3.9.5",
    "prettier-plugin-organize-attributes": "1.0.0",
    "prettier-plugin-sort-json": "4.2.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "1.4.0",
    "typescript": "7.0.2",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10",
    "vitest-canvas-mock": "1.1.4"
  }
}
